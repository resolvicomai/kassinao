# Copy this file to .env, then immediately run `chmod 600 .env`. Never paste
# populated values into issues, chat, screenshots, shell commands or logs.

# Bot token (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal > General Information)
APPLICATION_ID=

# Client Secret (Discord Developer Portal > OAuth2 > Client Secret)
# Used by the "Sign in with Discord" login on the downloads page.
DISCORD_CLIENT_SECRET=

# Required for a private instance: Discord server IDs accepted by this bot.
# Copy each ID with Discord Developer Mode and separate multiple IDs with commas.
ALLOWED_GUILD_IDS=

# Deliberate public multi-guild mode. Keep false for a private/self-hosted bot.
# This cannot be true at the same time as ALLOWED_GUILD_IDS.
ALLOW_ALL_GUILDS=false

# Optional command-registration filter. It does NOT grant access and must be one
# of ALLOWED_GUILD_IDS. Leave empty to register in every allowed server.
GUILD_ID=

# Bare-node listener. It is loopback-only by default so running Node directly
# on a VPS does not accidentally publish the app. Docker overrides the internal
# listener to 0.0.0.0 inside the container while publishing only 127.0.0.1 on
# the host. Use KASSINAO_HOST_PORT to change Docker's host-side port.
PORT=8080
WEB_BIND_ADDRESS=127.0.0.1
# KASSINAO_HOST_PORT=8080

# Canonical origin for the private app, Discord OAuth, recording links and
# downloads. Local/testing: leave as is. Production must use your HTTPS origin.
APP_URL=http://localhost:8080

# Legacy alias for APP_URL. New installations should leave this empty. If both
# are set, they must be exactly equal or startup fails.
BASE_URL=

# Optional split-domain topology. Set only when these surfaces use different
# origins. Values must be origins only:
# no path, query string, fragment or credentials.
#
# IMPORTANT: register APP_URL + /auth/callback in Discord Developer Portal >
# OAuth2 > Redirects.
#
# PUBLIC_URL: public landing and demo.
# PUBLIC_URL=https://example.com
#
# DOCS_URL: documentation. Its root is the default-language docs page.
# DOCS_URL=https://docs.example.com
#
# MCP_URL: private API origin consumed by kassinao-mcp. Public project links
# point to the docs/npm package, never to another operator's API.
# MCP_URL=https://mcp.example.com

# Exact trusted reverse-proxy hop count. Keep 0 without a proxy. Use 1 with the
# bundled Cloudflare Tunnel topology. Never increase it "just in case".
TRUST_PROXY_HOPS=0

# Source repository linked by /about and public surfaces. Forks should replace
# this with their own public source URL to comply with the AGPL.
SOURCE_URL=https://github.com/resolvicomai/kassinao

# Cloudflare Tunnel token (created in the Cloudflare Zero Trust dashboard).
# It binds your https address to the bot without opening ports on the VPS.
# The bundled cloudflared service only starts under the "tunnel" compose
# profile — uncomment the line below to enable it (or run
# `docker compose --profile tunnel up -d`). Without the profile it never starts.
TUNNEL_TOKEN=
# COMPOSE_PROFILES=tunnel

# Set to true when your GitHub repo is public: the landing page then shows the
# GitHub/source links and the "auditable" claim. Default: false (no 404 links).
REPO_PUBLIC=

# Optional: secret (at least 32 bytes) used to sign web session cookies.
# If empty, a strong random secret is generated and stored with mode 0600 in
# RECORDINGS_DIR/.cookie-secret. Generate manually with: openssl rand -hex 32
COOKIE_SECRET=

# Where recordings are stored (in Docker this is overridden to /app/recordings)
RECORDINGS_DIR=./recordings

# Container resource ceilings and non-root UID/GID. Defaults fit a small VPS;
# raise memory for larger local transcription models. Existing root-owned
# recordings need a one-time: sudo chown -R 1000:1000 recordings
# KASSINAO_UID=1000
# KASSINAO_GID=1000
# KASSINAO_MEMORY_LIMIT=3g
# KASSINAO_CPUS=2.0

# Tiered retention: AUDIO expires after RETENTION_DAYS (heavy files), while the
# TEXT (transcript + minutes + notes) lives on for TEXT_RETENTION_DAYS — so
# search, /ask and the MCP connector keep working long after the audio is gone.
# TEXT_RETENTION_DAYS is never allowed to be lower than RETENTION_DAYS.
# RETENTION_DAYS=0 = UNLIMITED: nothing ever expires on its own (audio AND text);
# deleting becomes 100% manual — the private /app page has per-recording
# "free up space" (audio only) and "delete all" actions for that.
RETENTION_DAYS=7
TEXT_RETENTION_DAYS=90

# Maximum length of a single recording, in hours
MAX_RECORDING_HOURS=6

# Hard anti-abuse ceilings. Manual and auto-record starts consume the same
# durable guild/global quotas; administrators only bypass the two UX cooldowns.
# Capacity is reserved before capture and held through cook + ASR + AI minutes.
RECORDING_MAX_CONCURRENT=2
RECORDING_GUILD_STARTS_PER_24H=12
RECORDING_STARTS_GLOBAL_PER_HOUR=8
RECORDING_STARTS_GLOBAL_PER_24H=32
RECORDING_MAX_PENDING_PROCESSING=12

# UX cooldowns for manual /record starts by regular members. Administrators
# bypass only these cooldowns, never the hard ceilings above.
MANUAL_RECORD_USER_COOLDOWN_SEC=60
MANUAL_RECORD_GUILD_COOLDOWN_SEC=15

# MP3 bitrate (individual tracks and the mix)
MP3_BITRATE=192k

# ---------------- Transcription (runs automatically after each recording) ----------------
# Engine: none | assemblyai | openai | groq | gemini | command
#   assemblyai -> requires ASSEMBLYAI_API_KEY (default model: universal-3-5-pro;
#                 optional Groq fallback requires TRANSCRIBE_FALLBACK_PROVIDER=groq)
#   openai  -> requires OPENAI_API_KEY  (default model: whisper-1, with timestamps)
#   groq    -> requires GROQ_API_KEY    (default model: whisper-large-v3)
#   gemini  -> requires GEMINI_API_KEY  (default model: gemini-3.5-flash)
#   command -> runs a local command (faster-whisper, whisper.cpp, Parakeet...) — full privacy
# Since each person has their own track, the transcript comes out with exact
# speaker names and timestamps. VAD normally sends only segments with speech.
# If detection fails, fixed chunks are used so the recording is not discarded.
TRANSCRIBE_PROVIDER=none

# External fallback is opt-in. A GROQ_API_KEY alone never enables it.
# none | groq
TRANSCRIBE_FALLBACK_PROVIDER=none

# Opt-in to sending participant names plus server/channel context to the ASR
# provider. False keeps operator vocabulary but omits meeting identity/context.
TRANSCRIBE_SEND_MEETING_CONTEXT=false

# Optional: overrides the default model of the chosen provider
TRANSCRIBE_MODEL=

# Language spoken in the calls
TRANSCRIBE_LANGUAGE=pt

# Optional: context prompt for the ASR (vocabulary/names/style). Improves the
# spelling of jargon and reduces hallucination. Used by Whisper AND by
# AssemblyAI's Universal-3.5-Pro (contextual prompting). Empty = neutral default.
# TRANSCRIBE_PROMPT=Weekly meeting of ACME's product team; participants: Ana, Bruno.

# Optional (AssemblyAI Universal-3.5-Pro only): fixed team vocabulary for
# keyterms prompting, comma-separated. Participant names are added only when
# TRANSCRIBE_SEND_MEETING_CONTEXT=true; use this for products/acronyms/projects.
# TRANSCRIBE_KEYTERMS=Kassinão, OKR Q3, Projeto Andrômeda

# API keys (only the one for the chosen provider)
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------- AI minutes (summary + decisions + action items, after transcription) ----------------
# Off by default. Set true only after choosing a provider and accepting that
# transcript text, participant/speaker names, voice-channel name and marked
# notes are sent to it. Audio is never sent to the minutes provider.
# 'false' (default) | 'true' | 'auto' (legacy compatibility).
MINUTES_ENABLED=false
# Minutes LLM provider: openrouter | groq. Default: openrouter when an
# OPENROUTER_API_KEY is set (better models, huge context — long calls don't
# overflow), otherwise groq (free, but capped at 12k tokens/min: long calls run
# in map-reduce, which is slower).
# MINUTES_PROVIDER=openrouter
# OpenRouter is a paid LLM gateway (one key, many models, own credits). Cost
# depends on the configured model and transcript size. https://openrouter.ai
OPENROUTER_API_KEY=
# Optional OpenRouter attribution origin. Blank omits HTTP-Referer entirely;
# no maintainer domain is sent for a self-hosted instance.
OPENROUTER_SITE_URL=
# Minutes model. Default: google/gemini-2.5-flash (openrouter) or llama-3.3-70b-versatile (groq).
# MINUTES_MODEL=
# Max output tokens for the minutes (8192 covers long meetings):
MINUTES_MAX_TOKENS=8192

# Optional operator webhook: every time minutes are ready, the bot POSTs a JSON
# {event:'minutes.ready', recordingId, url, guildName, channelName, startedAt,
# endedAt, participants, minutes} to this URL — handy for self-hosted
# integrations (n8n → Notion/Jira/etc). Security: this can ONLY be set here in
# the env (never via Discord). Non-local destinations must use HTTPS.
MINUTES_WEBHOOK_URL=
# Required whenever MINUTES_WEBHOOK_URL is set. Use a dedicated value with at
# least 32 bytes. The receiver must verify timestamp and HMAC before accepting.
MINUTES_WEBHOOK_SECRET=

# For the LOCAL transcriber (scripts/transcribe-local.py): faster-whisper model size.
# tiny/base/small run on CPU; medium/large-v3 need plenty of RAM or a GPU.
WHISPER_MODEL=small

# For TRANSCRIBE_PROVIDER=command: an executable plus arguments with the
# standalone placeholders {input} (mono 16kHz mp3) and {output} (the command
# MUST write there a JSON array: [{"start":s,"end":s,"text":"..."}]).
# Quotes are supported for arguments with spaces. Shell expansion, pipes,
# redirects, globs, comments and embedded placeholders are rejected.
# Example with faster-whisper (ready-made wrapper in scripts/transcribe-local.py, see README):
#   TRANSCRIBE_COMMAND=python3 ./scripts/transcribe-local.py {input} {output}
TRANSCRIBE_COMMAND=

# Extra environment variable names deliberately passed to the local command,
# comma-separated. Empty is safest. Discord/MCP/cookie/provider secrets are not
# inherited automatically.
TRANSCRIBE_COMMAND_ENV_ALLOWLIST=

# Watchdog for the 'command' provider: timeout = max(10min, chunk_duration × factor).
# Increase it when running a large local model on a weak CPU (5 = tolerates up to 5× realtime).
TRANSCRIBE_TIMEOUT_FACTOR=5

# Timezone for dates (transcript .md and web page fallback; the visitor's
# browser takes priority on the web). E.g.: America/Sao_Paulo, UTC, Europe/Lisbon.
TZ=America/Sao_Paulo

# Default language when no user locale is available (e.g. DM replies to the bot).
# Default 'en'. Set 'pt' to reply in Portuguese. Inside servers, each person
# still sees messages in their own Discord client language.
DEFAULT_LOCALE=en

# ---------------- MCP connector (optional) ----------------
# Enables the /api/* API, the /app/conectar-ia page and the /mcp command, to plug
# your meetings into your AI assistant (Claude Desktop, Cursor…). OFF by
# default: it only turns on when MCP_SECRET has a value.
#
# MCP_SECRET: a strong, DEDICATED secret (≠ COOKIE_SECRET). It is NOT
# auto-generated — set it yourself (e.g. `openssl rand -hex 32`). Rotating it
# revokes ALL connectors at once (panic button). Each person's access stays the
# SAME as on the web page (they only see what they'd already see); the token
# never widens permissions.
MCP_SECRET=
# Discord IDs allowed to use the /mcp command (CSV). Regular members use the
# self-serve /app/conectar-ia page instead. E.g.: OWNER_IDS=123456789012345678
OWNER_IDS=
# Access token lifetime (minutes) and refresh token lifetime (days). Safe defaults.
MCP_ACCESS_TTL_MIN=15
MCP_REFRESH_TTL_DAYS=30

# ---------------- Robustness / ops (optional) ----------------
# Disk guard: refuses to START a recording below MIN_FREE_MB_START and STOPS
# the recording in progress below MIN_FREE_MB_ABORT (prevents corrupted tracks).
MIN_FREE_MB_START=500
MIN_FREE_MB_ABORT=150
# Disk usage (%) that triggers a DM alert to the OWNER_IDS.
DISK_ALERT_PCT=85
# Off-site backup is a HOST cron job, not an app setting: pass these variables
# to scripts/backup.sh from a mode-0600 systemd EnvironmentFile or crontab owned
# by the deployment user. Set RECORDINGS_DIR to an absolute host path when the
# script is installed outside this repository. The
# script refuses plaintext remotes and verifies every upload end to end.
# RCLONE_CONFIG=/home/kassinao/.config/rclone/kassinao-upload.conf
# RCLONE_REMOTE=kassinao-backup:my-bucket
# Retention should use provider lifecycle/object lock. The separate
# scripts/backup-retention.sh requires a different config/credential with delete
# permission plus RCLONE_RETENTION_REMOTE and BACKUP_KEEP_DAYS.
