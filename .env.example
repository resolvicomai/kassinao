# Token do bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal > General Information)
APPLICATION_ID=

# Client Secret (Discord Developer Portal > OAuth2 > Client Secret)
# Usado no "entrar com Discord" da página de downloads.
DISCORD_CLIENT_SECRET=

# Opcional: ID do seu servidor Discord. Se definido, os comandos aparecem
# na hora (só nesse servidor). Sem isso, o registro global pode levar até 1h.
GUILD_ID=

# Porta do servidor web
PORT=8080

# URL pública usada nos links enviados no Discord e no login OAuth.
# Local/teste: deixe como está (localhost). Produção: troque pela sua URL pública,
# ex. com Cloudflare Tunnel: https://kassinao.seu-dominio.com
# IMPORTANTE: cadastre BASE_URL + /auth/callback como Redirect URI no
# Developer Portal > OAuth2 (ex.: https://kassinao.seu-dominio.com/auth/callback),
# senão o login da página de download falha.
BASE_URL=http://localhost:8080

# Token do Cloudflare Tunnel (criado no painel Zero Trust da Cloudflare).
# É o que liga o endereço https ao bot sem abrir portas no VPS.
TUNNEL_TOKEN=

# Opcional: segredo dos cookies de sessão da página web.
# Se vazio, um segredo aleatório é gerado e salvo em RECORDINGS_DIR/.cookie-secret.
COOKIE_SECRET=

# Onde salvar as gravações (no Docker isso é sobrescrito para /app/recordings)
RECORDINGS_DIR=./recordings

# Dias até as gravações expirarem e serem apagadas
RETENTION_DAYS=7

# Duração máxima de uma gravação, em horas
MAX_RECORDING_HOURS=6

# Bitrate dos MP3 (faixas individuais e mix)
MP3_BITRATE=192k

# ---------------- Transcrição (automática ao fim de cada gravação) ----------------
# Motor: none | assemblyai | openai | groq | gemini | command
#   assemblyai -> exige ASSEMBLYAI_API_KEY (modelo padrão: universal — top-3 em pt-BR;
#                 US$50 de crédito grátis na conta nova; se falhar e houver GROQ_API_KEY,
#                 cai sozinho pro Whisper da Groq)
#   openai  -> exige OPENAI_API_KEY  (modelo padrão: whisper-1, com timestamps)
#   groq    -> exige GROQ_API_KEY    (modelo padrão: whisper-large-v3; free tier 8h de áudio/dia)
#   gemini  -> exige GEMINI_API_KEY  (modelo padrão: gemini-2.0-flash)
#   command -> roda um comando local (faster-whisper, whisper.cpp, Parakeet...) — privacidade total
# Como cada pessoa tem faixa própria, a transcrição sai com nome do falante e timestamps exatos.
# Só os trechos com FALA são enviados (VAD por silencedetect): menos custo/cota e
# zero alucinação de silêncio.
TRANSCRIBE_PROVIDER=none

# Opcional: sobrescreve o modelo do provider escolhido
TRANSCRIBE_MODEL=

# Idioma falado nas calls
TRANSCRIBE_LANGUAGE=pt

# Opcional: prompt de contexto pro Whisper (vocabulário/nomes/estilo). Ajuda na
# grafia de jargões e reduz alucinação. Vazio = usa um padrão neutro em pt-BR.
# TRANSCRIBE_PROMPT=Reunião semanal do time de produto da ACME; participantes: Ana, Bruno.

# Chaves de API (só a do provider escolhido)
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------- Ata com IA (resumo + decisões + tarefas, após a transcrição) ----------------
# Liga sozinha quando há OPENROUTER_API_KEY ou GROQ_API_KEY. Manda só TEXTO ao LLM, nunca áudio.
# 'auto' (padrão) | 'true' (força) | 'false' (desliga).
MINUTES_ENABLED=auto
# Provider do LLM da ata: openrouter | groq. Padrão: openrouter quando há
# OPENROUTER_API_KEY (modelos melhores, contexto gigante — call longa não estoura),
# senão groq (free, mas com limite de 12k tokens/min: calls longas rodam em
# map-reduce, mais lento).
# MINUTES_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Modelo da ata. Padrão: google/gemini-2.5-flash (openrouter) ou llama-3.3-70b-versatile (groq).
# MINUTES_MODEL=
# Teto de tokens de saída da ata (8192 cobre reuniões longas):
MINUTES_MAX_TOKENS=8192

# Para o transcritor LOCAL (scripts/transcribe-local.py): tamanho do modelo faster-whisper.
# tiny/base/small rodam em CPU; medium/large-v3 pedem bastante RAM ou GPU.
WHISPER_MODEL=small

# Para TRANSCRIBE_PROVIDER=command: comando com os placeholders {input} (mp3 mono 16kHz)
# e {output} (o comando DEVE escrever nesse caminho um JSON [{"start":s,"end":s,"text":"..."}]).
# Exemplo com faster-whisper (veja o wrapper pronto em scripts/transcribe-local.py no README):
#   TRANSCRIBE_COMMAND=python3 ./scripts/transcribe-local.py {input} {output}
TRANSCRIBE_COMMAND=

# Watchdog do provider 'command': timeout = max(10min, duração_do_chunk × fator).
# Aumente se usar um modelo local grande em CPU fraca (5 = tolera até 5× tempo real).
TRANSCRIBE_TIMEOUT_FACTOR=5

# Fuso horário das datas (transcrição .md e fallback da página web; o navegador
# de quem abre a página tem prioridade). Ex.: America/Sao_Paulo, UTC, Europe/Lisbon.
TZ=America/Sao_Paulo

# Idioma padrão onde não há locale do usuário (ex.: resposta de DM ao bot).
# Padrão 'en'. Defina 'pt' para responder em português. Dentro dos servidores,
# cada pessoa continua vendo no idioma do próprio cliente Discord.
DEFAULT_LOCALE=en

# ---------------- Conector MCP (opcional) ----------------
# Liga a API /api/*, a página /conectar-ia e o comando /mcp, para plugar as
# reuniões no seu assistente de IA (Claude Desktop, Cursor…). DESLIGADO por padrão:
# só ativa quando MCP_SECRET tem valor.
#
# MCP_SECRET: segredo forte e DEDICADO (≠ COOKIE_SECRET). NÃO é auto-gerado —
# defina você mesmo (ex.: `openssl rand -hex 32`). Rotacioná-lo revoga TODOS os
# conectores de uma vez (botão de pânico). O acesso de cada pessoa continua sendo
# o MESMO da página web (só vê o que já veria); o token não amplia permissão.
MCP_SECRET=
# IDs Discord autorizados a usar o comando /mcp (CSV). Membros comuns usam a
# página /conectar-ia (self-serve). Ex.: OWNER_IDS=123456789012345678
OWNER_IDS=
# Vida do token de acesso (minutos) e do token de refresh (dias). Padrões seguros.
MCP_ACCESS_TTL_MIN=15
MCP_REFRESH_TTL_DAYS=30

# ---------------- Robustez / ops (opcional) ----------------
# Guarda de disco: recusa INICIAR gravação abaixo de MIN_FREE_MB_START e ENCERRA
# a gravação em curso abaixo de MIN_FREE_MB_ABORT (evita faixa corrompida).
MIN_FREE_MB_START=500
MIN_FREE_MB_ABORT=150
# Uso de disco (%) que dispara alerta por DM ao(s) OWNER_IDS.
DISK_ALERT_PCT=85
# Backup externo (scripts/backup.sh) — veja o cabeçalho do script pra configurar o rclone.
# RCLONE_REMOTE=kassinao-backup:meu-bucket
# BACKUP_KEEP_DAYS=30
