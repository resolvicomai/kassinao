# Copy this file to .env, then immediately run `chmod 600 .env`. Never paste
# populated values into issues, chat, screenshots, shell commands or logs.

# A source checkout builds this local development image before Compose starts.
# The verified production bundle replaces it with an immutable image@sha256;
# never copy this local value into a VPS release.
KASSINAO_IMAGE=kassinao-local:dev
KASSINAO_PULL_POLICY=never
# The verified production bundle fills this with the exact sha256 digest from
# KASSINAO_IMAGE. Leave blank for a source checkout/quick start.
KASSINAO_RELEASE_DIGEST=
# The production injector creates a new random, non-secret value per instance.
# Never copy the maintainer's or another operator's fingerprint.
KASSINAO_DEPLOYMENT_FINGERPRINT=

# Compose can keep its deployment/tunnel values in .env and load application
# credentials from a different 0600 file (recommended in production).
KASSINAO_APP_ENV_FILE=.env

# New installs keep data classes in different host directories. Existing
# installs without these variables keep using ./recordings for compatibility.
KASSINAO_RECORDINGS_DIR=./data/recordings
KASSINAO_STATE_DIR=./data/state
KASSINAO_AUTH_DIR=./data/auth
KASSINAO_MODEL_CACHE_DIR=./data/cache

# Bot token (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal > General Information)
APPLICATION_ID=

# Client Secret (Discord Developer Portal > OAuth2 > Client Secret)
# Used by the "Sign in with Discord" login on the downloads page.
DISCORD_CLIENT_SECRET=

# Required for a private instance: Discord server IDs accepted by this bot.
# Copy each ID with Discord Developer Mode and separate multiple IDs with commas.
ALLOWED_GUILD_IDS=

# Deliberate public multi-guild mode. Keep false for a private/self-hosted bot.
# This cannot be true at the same time as ALLOWED_GUILD_IDS.
ALLOW_ALL_GUILDS=false

# Optional command-registration filter. It does NOT grant access and must be one
# of ALLOWED_GUILD_IDS. Leave empty to register in every allowed server.
GUILD_ID=

# Bare-node listener. It is loopback-only by default so running Node directly
# on a VPS does not accidentally publish the app. Docker overrides the internal
# listener to 0.0.0.0 inside the container while publishing only 127.0.0.1 on
# the host. Use KASSINAO_HOST_PORT to change Docker's host-side port.
PORT=8080
WEB_BIND_ADDRESS=127.0.0.1
# KASSINAO_HOST_PORT=8080

# Canonical origin for the private app, Discord OAuth, recording links and
# downloads. Intentionally blank: every operator must choose their own origin.
# Local-only example: http://localhost:8080 plus ALLOW_LOCAL_APP_URL=true.
# Internet-facing deployments must use their own HTTPS origin.
APP_URL=
ALLOW_LOCAL_APP_URL=false

# Identity and privacy policy of THIS installation. These values are shown to
# users and must identify the actual operator, never the Kassinão project or a
# different hosted instance. The container runs with NODE_ENV=production even
# on localhost, so every non-optional policy field below must be filled before
# Docker starts. The README has a fictional-data-only localhost example.
#
# Public example:
# OPERATOR_NAME=Your company or name
# OPERATOR_CONTACT_URL=https://your-domain.example/contact
# PRIVACY_POLICY_URL=https://app.your-domain.example/privacy
# DATA_DELETION_URL=https://app.your-domain.example/privacy#data-rights
#
# Local Docker example (only with APP_URL=http://localhost:8080 and
# ALLOW_LOCAL_APP_URL=true):
# OPERATOR_NAME=Local Kassinão operator
# OPERATOR_CONTACT_URL=http://localhost:8080/privacy#contact
# PRIVACY_POLICY_URL=http://localhost:8080/privacy
# DATA_DELETION_URL=http://localhost:8080/privacy#data-rights
OPERATOR_NAME=
OPERATOR_CONTACT_URL=
PRIVACY_POLICY_URL=
DATA_DELETION_URL=
# Optional operator-specific terms page. Do not point this at another instance.
TERMS_OF_SERVICE_URL=

# Canonical policy contract for THIS installation. Production fails closed when
# any required statement is missing. Write public descriptions only: never put
# an IP, private hostname, account/guild ID, e-mail or secret in these fields.
# The policy page escapes every value and rejects common infrastructure
# coordinates, but the operator remains responsible for factual wording.
PRIVACY_EFFECTIVE_DATE=
PRIVACY_POLICY_VERSION=
PRIVACY_AUDIENCE=
PRIVACY_PURPOSES=
PRIVACY_LAWFUL_BASIS=

# Provider and coarse public region/scope only. Do not expose the VPS name,
# project/account ID, datacenter hostname or IP. For a truly local quickstart,
# explicit values such as "Local machine" and "Local device" are acceptable.
INFRASTRUCTURE_PROVIDER=
INFRASTRUCTURE_REGION=
# Use EDGE_PROVIDER=none and EDGE_REGION=none only when there is no tunnel,
# CDN, reverse-proxy service or other edge provider. Otherwise name the actual
# provider and public region/scope (for a global service, use "global").
EDGE_PROVIDER=none
EDGE_REGION=none

# Factual retention statement for operational logs across Docker/systemd and
# the hosting/edge provider. Describe limits or deletion timing, without paths
# or host coordinates. LOG_PII below states whether private values may appear.
OPERATIONAL_LOG_RETENTION=

# Backup must be explicit. disabled requires empty/none provider and region and
# 0/empty retention. enabled requires the actual provider, public region and a
# 1..3650 day retention. This metadata does not enable backups by itself.
BACKUP_STATUS=disabled
BACKUP_PROVIDER=none
BACKUP_REGION=none
BACKUP_RETENTION_DAYS=0

# Explain identity verification and delivery using the contact above; do not
# repeat an e-mail/URL in free text. The window is a public operator commitment
# and cannot extend a shorter legal deadline.
DATA_REQUEST_PROCESS=
DATA_REQUEST_RESPONSE_DAYS=30

# Incident contact can equal OPERATOR_CONTACT_URL, but must be written
# explicitly in production. Describe triage/notification without private
# channels, hostnames or IDs.
INCIDENT_CONTACT_URL=
INCIDENT_PROCESS=

# Legacy alias for APP_URL. New installations should leave this empty. If both
# are set, they must be exactly equal or startup fails.
BASE_URL=

# The Compose quickstart now uses the secret-free router as its only listener.
# Set all four origins explicitly even when they share http://localhost:8080,
# then start the `split-public` profile. Core and public publish no host ports.
# Optional split-domain topology. Values must be origins only:
# no path, query string, fragment or credentials.
#
# IMPORTANT: register APP_URL + /auth/callback in Discord Developer Portal >
# OAuth2 > Redirects.
#
# PUBLIC_URL: public landing and demo. Required with profile split-public.
# PUBLIC_URL=https://example.com
#
# DOCS_URL: documentation. Required with split-public; root serves default language.
# DOCS_URL=https://docs.example.com
#
# MCP_URL: private API origin consumed by kassinao-mcp. Public project links
# point to the docs/npm package, never to another operator's API.
# MCP_URL=https://mcp.example.com

# Bare-node single topology: true, with one core serving every configured
# surface. Docker Compose uses split topology: false plus the `split-public`
# profile, so ingress, public surfaces and the private core remain separate.
PUBLIC_SURFACES_ENABLED=true

# Exact trusted reverse-proxy hop count. Keep 0 without a proxy. Use 1 with the
# bundled Cloudflare Tunnel topology. Never increase it "just in case".
TRUST_PROXY_HOPS=0

# Source repository linked by /about and public surfaces. Production requires
# an explicit URL for the exact source offered by this operator. Forks must
# never inherit the upstream project's URL silently. Local non-production
# development falls back to the upstream checkout when this remains blank;
# Docker runs in production mode, including on localhost, so Docker users set it.
SOURCE_URL=

# Cloudflare Tunnel token (created in the Cloudflare Zero Trust dashboard).
# It binds your https address to the bot without opening ports on the VPS.
# The bundled cloudflared service only starts under the "tunnel" compose
# profile — uncomment the line below to enable it (or run
# `docker compose --profile tunnel up -d`). Compose quickstart requires
# `split-public`; production may add `tunnel`.
TUNNEL_TOKEN=
# COMPOSE_PROFILES=split-public

# Controls the optional source shortcut in the private app sidebar. It does not
# hide /about or change the operator's AGPL obligation; SOURCE_URL remains the
# source of truth. The secretless public process always exposes its source link.
REPO_PUBLIC=

# Optional: secret (at least 32 bytes) used to sign web session cookies.
# If empty, a strong random secret is generated and stored with mode 0600 in
# AUTH_STATE_DIR/.cookie-secret. A separate .instance-id binds cookies and MCP
# tokens to this installation. Generate a cookie secret with: openssl rand -hex 32
COOKIE_SECRET=

# Bare-node data paths. Docker overrides these with three isolated mounts.
RECORDINGS_DIR=./recordings
STATE_DIR=./state
AUTH_STATE_DIR=./auth

# Container resource ceilings and non-root UID/GID. Defaults fit a small VPS;
# raise memory for larger local transcription models. For brand-new local-only
# dirs, create each directly as 0700/1000:1000. Never recursively take ownership
# of an existing/shared tree; production preparation scripts verify every path.
# Dedicated/local pode usar 1000:1000. Shared exige valores explícitos privados
# na faixa 61000..61183, escolhidos após os gates do kit operacional.
# KASSINAO_UID=
# KASSINAO_GID=
# KASSINAO_MEMORY_LIMIT=3g
# KASSINAO_CPUS=2.0

# Tiered retention: AUDIO expires after RETENTION_DAYS (heavy files), while the
# TEXT (transcript + minutes + notes) lives on for TEXT_RETENTION_DAYS — so
# search, /ask and the MCP connector keep working long after the audio is gone.
# TEXT_RETENTION_DAYS is never allowed to be lower than RETENTION_DAYS.
# RETENTION_DAYS=0 = UNLIMITED: nothing ever expires on its own (audio AND text);
# deleting becomes 100% manual — the private /app page has per-recording
# "free up space" (audio only) and "delete all" actions for that.
RETENTION_DAYS=7
TEXT_RETENTION_DAYS=90

# Maximum length of a single recording, in hours
MAX_RECORDING_HOURS=6

# Hard anti-abuse ceilings. Manual and auto-record starts consume the same
# durable guild/global quotas; administrators only bypass the two UX cooldowns.
# Capacity is reserved before capture and held through cook + ASR + AI minutes.
RECORDING_MAX_CONCURRENT=2
RECORDING_GUILD_STARTS_PER_24H=12
RECORDING_STARTS_GLOBAL_PER_HOUR=8
RECORDING_STARTS_GLOBAL_PER_24H=32
RECORDING_MAX_PENDING_PROCESSING=12

# UX cooldowns for manual /record starts by regular members. Administrators
# bypass only these cooldowns, never the hard ceilings above.
MANUAL_RECORD_USER_COOLDOWN_SEC=60
MANUAL_RECORD_GUILD_COOLDOWN_SEC=15

# MP3 bitrate (individual tracks and the mix)
MP3_BITRATE=192k

# ---------------- Optional transcription (runs after recording only when selected) ----------------
# Engine: none | assemblyai | openai | groq | gemini | command
#   assemblyai -> requires ASSEMBLYAI_API_KEY (default model: universal-3-5-pro;
#                 optional Groq fallback requires TRANSCRIBE_FALLBACK_PROVIDER=groq)
#   openai  -> requires OPENAI_API_KEY  (default model: whisper-1, with timestamps)
#   groq    -> requires GROQ_API_KEY    (default model: whisper-large-v3)
#   gemini  -> requires GEMINI_API_KEY  (default model: gemini-3.5-flash)
#   command -> custom-image-only: the operator adds and maintains the executable.
#              The command receives audio and may be local or network-capable;
#              review it separately before treating this path as local-only.
# Each Discord account that speaks has a separate track. Transcript labels come
# from that Discord account; they do not prove human identity. ASR timestamps and
# tracks can be partial. VAD normally sends only speech segments; fixed chunks
# are used when detection fails so the whole recording is not discarded.
TRANSCRIBE_PROVIDER=none

# External fallback is opt-in. A GROQ_API_KEY alone never enables it.
# none | groq
TRANSCRIBE_FALLBACK_PROVIDER=none

# Opt-in to sending participant names plus server/channel context to the ASR
# provider. False keeps operator vocabulary but omits meeting identity/context.
TRANSCRIBE_SEND_MEETING_CONTEXT=false

# Optional: overrides the default model of the chosen provider
TRANSCRIBE_MODEL=

# Language spoken in the calls
TRANSCRIBE_LANGUAGE=en

# Optional: context prompt for the ASR (vocabulary/names/style). Improves the
# spelling of jargon and reduces hallucination. Used by Whisper AND by
# AssemblyAI's Universal-3.5-Pro (contextual prompting). Empty = neutral default.
# TRANSCRIBE_PROMPT=Weekly meeting of ACME's product team; participants: Ana, Bruno.

# Optional (AssemblyAI Universal-3.5-Pro only): fixed team vocabulary for
# keyterms prompting, comma-separated. Participant names are added only when
# TRANSCRIBE_SEND_MEETING_CONTEXT=true; use this for products/acronyms/projects.
# TRANSCRIBE_KEYTERMS=Kassinão, OKR Q3, Projeto Andrômeda

# API keys (only the one for the chosen provider)
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------- AI minutes (summary + decisions + action items, after transcription) ----------------
# Off by default. Set true only after choosing a provider and accepting that
# transcript text, participant/speaker names, voice-channel name and marked
# notes are sent to it. Audio is never sent to the minutes provider.
# 'false' (default) | 'true' | 'auto' (legacy compatibility).
MINUTES_ENABLED=false
# Minutes LLM provider: openrouter | groq. The current compatibility fallback is
# openrouter when OPENROUTER_API_KEY exists, otherwise groq. Set this explicitly
# before enabling minutes; pricing, model limits and rate limits belong to the
# selected provider and can change independently of Kassinão.
# MINUTES_PROVIDER=openrouter
# Provider billing depends on the configured model and transcript size. Review
# the provider's current terms and data policy before enabling it.
OPENROUTER_API_KEY=
# Optional OpenRouter attribution origin. Blank omits HTTP-Referer entirely;
# no maintainer domain is sent for a self-hosted instance.
OPENROUTER_SITE_URL=
# Minutes model. Default: google/gemini-2.5-flash (openrouter) or llama-3.3-70b-versatile (groq).
# MINUTES_MODEL=
# Max output tokens for the minutes (8192 covers long meetings):
MINUTES_MAX_TOKENS=8192

# Optional operator webhook: every time minutes are ready, the bot POSTs a JSON
# {event:'minutes.ready', recordingId, url, guildName, channelName, startedAt,
# endedAt, participants, minutes} to this URL — handy for self-hosted
# integrations (n8n → Notion/Jira/etc). Security: this can ONLY be set here in
# the env (never via Discord). Non-local destinations must use HTTPS.
MINUTES_WEBHOOK_URL=
# Required whenever MINUTES_WEBHOOK_URL is set. Use a dedicated value with at
# least 32 bytes. The receiver must verify timestamp and HMAC before accepting.
MINUTES_WEBHOOK_SECRET=

# Custom images only: model used by scripts/transcribe-local.py. The standard
# release image does not install Python or faster-whisper.
WHISPER_MODEL=small

# For TRANSCRIBE_PROVIDER=command: an executable plus arguments with the
# standalone placeholders {input} (mono 16kHz mp3) and {output} (the command
# MUST write there a JSON array: [{"start":s,"end":s,"text":"..."}]).
# Quotes are supported for arguments with spaces. Shell expansion, pipes,
# redirects, globs, comments and embedded placeholders are rejected.
# Example for a custom image containing faster-whisper (see README):
#   TRANSCRIBE_COMMAND=python3 ./scripts/transcribe-local.py {input} {output}
TRANSCRIBE_COMMAND=

# Extra environment variable names deliberately passed to the local command,
# comma-separated. Empty is safest. Names that look like credentials (TOKEN,
# SECRET, PASSWORD, KEY, AUTH, COOKIE, CREDENTIALS) or can alter a loader,
# shell, interpreter or TLS/network-client configuration are always rejected. Give a local engine
# credentials through its own root-only file when needed.
TRANSCRIBE_COMMAND_ENV_ALLOWLIST=

# Watchdog for the 'command' provider: timeout = max(10min, chunk_duration × factor).
# Increase it when running a large local model on a weak CPU (5 = tolerates up to 5× realtime).
TRANSCRIBE_TIMEOUT_FACTOR=5

# Timezone for dates (transcript .md and web page fallback; the visitor's
# browser takes priority on the web). E.g.: America/Sao_Paulo, UTC, Europe/Lisbon.
TZ=UTC

# Default language when no user locale is available (e.g. DM replies to the bot).
# Default 'en'. Set 'pt' to reply in Portuguese. Inside servers, each person
# still sees messages in their own Discord client language.
DEFAULT_LOCALE=en

# ---------------- MCP connector (optional) ----------------
# Enables the /api/* API, the /app/conectar-ia page and the /mcp command for a
# compatible local MCP host. OFF by default: setting MCP_SECRET is the opt-in.
#
# MCP_SECRET: a strong, DEDICATED secret (≠ COOKIE_SECRET). It is NOT
# auto-generated — set it yourself (e.g. `openssl rand -hex 32`). Rotating it
# revokes ALL connectors at once (panic button). Each person's access stays the
# SAME as on the web page (they only see what they'd already see); the token
# never widens permissions.
MCP_SECRET=
# Discord IDs allowed to use the /mcp command (CSV). Regular members use the
# self-serve /app/conectar-ia page instead. E.g.: OWNER_IDS=123456789012345678
OWNER_IDS=
# Access token lifetime (minutes) and refresh token lifetime (days). Safe defaults.
MCP_ACCESS_TTL_MIN=15
MCP_REFRESH_TTL_DAYS=30

# ---------------- Robustness / ops (optional) ----------------
# Disk guard: refuses to START a recording below MIN_FREE_MB_START and STOPS
# the recording in progress below MIN_FREE_MB_ABORT (prevents corrupted tracks).
MIN_FREE_MB_START=500
MIN_FREE_MB_ABORT=150
# Disk usage (%) that triggers a DM alert to the OWNER_IDS.
DISK_ALERT_PCT=85
# Operational logs redact user/guild/channel/session/recording identifiers,
# private routes, origins and error messages. Enable only for a short, controlled
# debugging window; logs with PII must never be pasted into public support.
LOG_PII=false
# The verified image-only deploy attempts to delete its operational-state
# snapshot immediately after success. If deployment or cleanup fails, its host
# timer enforces removal within 1..168 hours. This value must match compose .env
# and app.env.
KASSINAO_ROLLBACK_RETENTION_HOURS=72
# Off-site backup is a HOST cron job, not an app setting: pass these variables
# to scripts/backup.sh from a mode-0600 systemd EnvironmentFile or crontab owned
# by the deployment user. Set absolute host RECORDINGS_DIR, STATE_DIR and
# AUTH_STATE_DIR paths. Auth is verified to be separate and is never archived.
# The script refuses a running core by default because tar is not a transactional
# snapshot. In an approved maintenance window, BACKUP_STOP_CONTAINER=true stops
# the core only while the local archive is created and validated, coordinates
# with the health watchdog, and starts it again before upload. The script also
# refuses plaintext remotes and verifies every upload end to end.
# BACKUP_STOP_CONTAINER=true
# Dedicated: keep this private path outside the release checkout. Shared: use
# exactly $KASSINAO_DATA_ROOT/config/backup-upload-rclone.conf inside LUKS,
# canonical, mode 0600 and without hardlinks.
# RCLONE_CONFIG=/var/lib/kassinao/config/backup-upload-rclone.conf
# RCLONE_REMOTE=kassinao-backup:my-bucket
# Retention should use provider lifecycle/object lock. The separate
# scripts/backup-retention.sh requires a different config/credential with delete
# permission plus RCLONE_RETENTION_REMOTE and BACKUP_KEEP_DAYS. Shared requires
# exactly $KASSINAO_DATA_ROOT/config/backup-retention-rclone.conf in the same
# LUKS mount, never the upload credential.
