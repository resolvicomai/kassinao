# Bot token (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal > General Information)
APPLICATION_ID=

# Client Secret (Discord Developer Portal > OAuth2 > Client Secret)
# Used by the "Sign in with Discord" login on the downloads page.
DISCORD_CLIENT_SECRET=

# Optional: your Discord server ID. If set, slash commands show up instantly
# (in that server only). Without it, global registration can take up to 1 hour.
GUILD_ID=

# Web server port
PORT=8080

# Public URL used in the links posted on Discord and for the OAuth login.
# Local/testing: leave as is (localhost). Production: replace with your public
# URL, e.g. with Cloudflare Tunnel: https://kassinao.your-domain.com
# IMPORTANT: register BASE_URL + /auth/callback as a Redirect URI in the
# Developer Portal > OAuth2 (e.g. https://kassinao.your-domain.com/auth/callback),
# otherwise the download-page login fails.
BASE_URL=http://localhost:8080

# Cloudflare Tunnel token (created in the Cloudflare Zero Trust dashboard).
# It binds your https address to the bot without opening ports on the VPS.
# The bundled cloudflared service only starts under the "tunnel" compose
# profile — uncomment the line below to enable it (or run
# `docker compose --profile tunnel up -d`). Without the profile it never starts.
TUNNEL_TOKEN=
# COMPOSE_PROFILES=tunnel

# Set to true when your GitHub repo is public: the landing page then shows the
# GitHub/source links and the "auditable" claim. Default: false (no 404 links).
REPO_PUBLIC=

# Optional: secret used to sign the web page session cookies.
# If empty, a random secret is generated and stored in RECORDINGS_DIR/.cookie-secret.
COOKIE_SECRET=

# Where recordings are stored (in Docker this is overridden to /app/recordings)
RECORDINGS_DIR=./recordings

# Days until recordings expire and are deleted
RETENTION_DAYS=7

# Maximum length of a single recording, in hours
MAX_RECORDING_HOURS=6

# MP3 bitrate (individual tracks and the mix)
MP3_BITRATE=192k

# ---------------- Transcription (runs automatically after each recording) ----------------
# Engine: none | assemblyai | openai | groq | gemini | command
#   assemblyai -> requires ASSEMBLYAI_API_KEY (default model: universal — top-3 for pt-BR;
#                 US$50 free credit on new accounts; if it fails and a GROQ_API_KEY
#                 is set, it falls back to Groq Whisper automatically)
#   openai  -> requires OPENAI_API_KEY  (default model: whisper-1, with timestamps)
#   groq    -> requires GROQ_API_KEY    (default model: whisper-large-v3; free tier: 8 audio-hours/day)
#   gemini  -> requires GEMINI_API_KEY  (default model: gemini-2.0-flash)
#   command -> runs a local command (faster-whisper, whisper.cpp, Parakeet...) — full privacy
# Since each person has their own track, the transcript comes out with exact
# speaker names and timestamps. Only segments with SPEECH are sent (VAD via
# silencedetect): lower cost/quota and zero silence hallucinations.
TRANSCRIBE_PROVIDER=none

# Optional: overrides the default model of the chosen provider
TRANSCRIBE_MODEL=

# Language spoken in the calls
TRANSCRIBE_LANGUAGE=pt

# Optional: context prompt for Whisper (vocabulary/names/style). Improves the
# spelling of jargon and reduces hallucination. Empty = a neutral pt-BR default.
# TRANSCRIBE_PROMPT=Weekly meeting of ACME's product team; participants: Ana, Bruno.

# API keys (only the one for the chosen provider)
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------- AI minutes (summary + decisions + action items, after transcription) ----------------
# Turns on by itself when OPENROUTER_API_KEY or GROQ_API_KEY is set. Only TEXT is
# sent to the LLM, never audio.
# 'auto' (default) | 'true' (force on) | 'false' (off).
MINUTES_ENABLED=auto
# Minutes LLM provider: openrouter | groq. Default: openrouter when an
# OPENROUTER_API_KEY is set (better models, huge context — long calls don't
# overflow), otherwise groq (free, but capped at 12k tokens/min: long calls run
# in map-reduce, which is slower).
# MINUTES_PROVIDER=openrouter
# OpenRouter is a paid LLM gateway (one key, many models, own credits) — the
# minutes cost roughly a few cents per meeting. https://openrouter.ai
OPENROUTER_API_KEY=
# Minutes model. Default: google/gemini-2.5-flash (openrouter) or llama-3.3-70b-versatile (groq).
# MINUTES_MODEL=
# Max output tokens for the minutes (8192 covers long meetings):
MINUTES_MAX_TOKENS=8192

# For the LOCAL transcriber (scripts/transcribe-local.py): faster-whisper model size.
# tiny/base/small run on CPU; medium/large-v3 need plenty of RAM or a GPU.
WHISPER_MODEL=small

# For TRANSCRIBE_PROVIDER=command: a command with the placeholders {input}
# (mono 16kHz mp3) and {output} (the command MUST write to that path a JSON
# array: [{"start":s,"end":s,"text":"..."}]).
# Example with faster-whisper (ready-made wrapper in scripts/transcribe-local.py, see README):
#   TRANSCRIBE_COMMAND=python3 ./scripts/transcribe-local.py {input} {output}
TRANSCRIBE_COMMAND=

# Watchdog for the 'command' provider: timeout = max(10min, chunk_duration × factor).
# Increase it when running a large local model on a weak CPU (5 = tolerates up to 5× realtime).
TRANSCRIBE_TIMEOUT_FACTOR=5

# Timezone for dates (transcript .md and web page fallback; the visitor's
# browser takes priority on the web). E.g.: America/Sao_Paulo, UTC, Europe/Lisbon.
TZ=America/Sao_Paulo

# Default language when no user locale is available (e.g. DM replies to the bot).
# Default 'en'. Set 'pt' to reply in Portuguese. Inside servers, each person
# still sees messages in their own Discord client language.
DEFAULT_LOCALE=en

# ---------------- MCP connector (optional) ----------------
# Enables the /api/* API, the /conectar-ia page and the /mcp command, to plug
# your meetings into your AI assistant (Claude Desktop, Cursor…). OFF by
# default: it only turns on when MCP_SECRET has a value.
#
# MCP_SECRET: a strong, DEDICATED secret (≠ COOKIE_SECRET). It is NOT
# auto-generated — set it yourself (e.g. `openssl rand -hex 32`). Rotating it
# revokes ALL connectors at once (panic button). Each person's access stays the
# SAME as on the web page (they only see what they'd already see); the token
# never widens permissions.
MCP_SECRET=
# Discord IDs allowed to use the /mcp command (CSV). Regular members use the
# self-serve /conectar-ia page instead. E.g.: OWNER_IDS=123456789012345678
OWNER_IDS=
# Access token lifetime (minutes) and refresh token lifetime (days). Safe defaults.
MCP_ACCESS_TTL_MIN=15
MCP_REFRESH_TTL_DAYS=30

# ---------------- Robustness / ops (optional) ----------------
# Disk guard: refuses to START a recording below MIN_FREE_MB_START and STOPS
# the recording in progress below MIN_FREE_MB_ABORT (prevents corrupted tracks).
MIN_FREE_MB_START=500
MIN_FREE_MB_ABORT=150
# Disk usage (%) that triggers a DM alert to the OWNER_IDS.
DISK_ALERT_PCT=85
# Off-site backup (scripts/backup.sh) — see the script header to configure rclone.
# RCLONE_REMOTE=kassinao-backup:my-bucket
# BACKUP_KEEP_DAYS=30
