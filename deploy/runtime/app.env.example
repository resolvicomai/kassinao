# Ambiente exclusivo do core privado. Copie para app.env, preencha e rode
# chmod 600 app.env. Nunca envie este arquivo para Git, issue, chat ou suporte.
DISCORD_TOKEN=
APPLICATION_ID=
DISCORD_CLIENT_SECRET=

# Origens desta instalação. Nenhuma delas pode apontar para a infraestrutura de
# outro operador. Cadastre exatamente APP_URL/auth/callback no Discord OAuth2.
APP_URL=
MCP_URL=
PUBLIC_URL=
DOCS_URL=
BASE_URL=
ALLOW_LOCAL_APP_URL=false
ALLOW_LEGACY_SHARED_STATE=false

# Identidade pública do operador desta instância. O injetor pergunta nome e
# contato e deriva as duas URLs canônicas abaixo de APP_URL. Nunca reutilize os
# dados da instância oficial ou de outro self-host.
OPERATOR_NAME=
OPERATOR_CONTACT_URL=
PRIVACY_POLICY_URL=
DATA_DELETION_URL=
# Opcional: página de termos do próprio operador.
TERMS_OF_SERVICE_URL=

# Contrato canônico publicado em /privacy. Todos os campos abaixo descrevem
# ESTA operação e são obrigatórios em produção, salvo os pares explicitamente
# marcados como none/disabled. Não inclua IP, hostname privado, ID ou segredo.
PRIVACY_EFFECTIVE_DATE=
PRIVACY_POLICY_VERSION=
PRIVACY_AUDIENCE=
PRIVACY_PURPOSES=
PRIVACY_LAWFUL_BASIS=
INFRASTRUCTURE_PROVIDER=
INFRASTRUCTURE_REGION=
# Use none/none somente sem túnel, CDN ou serviço de borda; caso contrário,
# informe o provider real e a região/escopo público (por exemplo, global).
EDGE_PROVIDER=
EDGE_REGION=
# Descreva rotação/expurgo de logs do container, host e provider sem caminhos.
OPERATIONAL_LOG_RETENTION=
# enabled exige provider, região e 1..3650 dias; disabled exige none/none/0.
BACKUP_STATUS=
BACKUP_PROVIDER=
BACKUP_REGION=
BACKUP_RETENTION_DAYS=
# Descreva verificação de identidade e entrega. A janela não substitui prazo
# legal menor. O contato de incidente pode repetir OPERATOR_CONTACT_URL.
DATA_REQUEST_PROCESS=
DATA_REQUEST_RESPONSE_DAYS=
INCIDENT_CONTACT_URL=
INCIDENT_PROCESS=

# Precisa coincidir com .env. A página de privacidade informa esta janela
# máxima; um deploy concluído remove o próprio snapshot antes disso.
KASSINAO_ROLLBACK_RETENTION_HOURS=72

# Perímetro Discord privado. IDs de guild/aplicação pertencem só à instância.
ALLOWED_GUILD_IDS=
ALLOW_ALL_GUILDS=false
GUILD_ID=
OWNER_IDS=

# No modo dividido, landing/docs/demo nunca são servidos pelo core com segredos.
PUBLIC_SURFACES_ENABLED=false
TRUST_PROXY_HOPS=1
SOURCE_URL=
REPO_PUBLIC=true

# Segredos locais. COOKIE_SECRET vazio é gerado no volume auth. MCP só liga com
# segredo dedicado; nunca reutilize token Discord, cookie ou chave de provider.
COOKIE_SECRET=
MCP_SECRET=

# Sem egress de conteúdo por padrão. Habilite somente o provider que escolheu.
TRANSCRIBE_PROVIDER=none
TRANSCRIBE_FALLBACK_PROVIDER=none
TRANSCRIBE_SEND_MEETING_CONTEXT=false
MINUTES_ENABLED=false
MINUTES_WEBHOOK_URL=
MINUTES_WEBHOOK_SECRET=

# Logs não expõem nomes, IDs, rotas privadas ou mensagens de erro por padrão.
LOG_PII=false
DEFAULT_LOCALE=en
TZ=UTC
