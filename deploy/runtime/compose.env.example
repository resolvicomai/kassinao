# Arquivo do Compose/túnel. Copie para .env, ajuste os caminhos/origens e rode
# chmod 600 .env. O bundle oficial substitui KASSINAO_IMAGE pelo digest exato.
KASSINAO_IMAGE=REPLACED_BY_VERIFIED_RELEASE_BUNDLE
# O bundle oficial substitui ambos pelo mesmo digest sha256 imutável.
KASSINAO_RELEASE_DIGEST=
# Nonce público da instância, gerado pelo injector e preservado entre releases.
KASSINAO_DEPLOYMENT_FINGERPRINT=
KASSINAO_PULL_POLICY=always
KASSINAO_APP_ENV_FILE=app.env
KASSINAO_DEPLOYMENT_MODE=split

# O escopo do host escolhe um adapter operacional explícito. `dedicated`
# preserva os controles que cercam o daemon Docker inteiro. `shared` usa o
# overlay e o installer próprios, sem tocar no lifecycle global do daemon.
KASSINAO_HOST_SCOPE=dedicated

# Limites obrigatórios do adapter shared. Estes valores reservam 25% de CPU e
# bem mais de 25% da RAM numa VPS de 2 vCPU / ~8 GiB. O auditor compara o .env,
# o Compose, o runtime e a capacidade real do host; não aceita unlimited nem
# soma que deixe menos de 25% para os workloads vizinhos. I/O precisa ser
# monitorado no host: sem um device estável não há throttle seguro para selar.
KASSINAO_CORE_MEMORY_LIMIT=2g
KASSINAO_CORE_CPUS=1.0
KASSINAO_PUBLIC_MEMORY_LIMIT=384m
KASSINAO_PUBLIC_CPUS=0.2
KASSINAO_TUNNEL_MEMORY_LIMIT=192m
KASSINAO_TUNNEL_CPUS=0.2

# O kit padrão instala ExecStartPre no docker.service inteiro. Use somente uma
# VPS dedicada ao Kassinão e copie literalmente a frase de aceite abaixo. No
# adapter shared, este campo precisa permanecer vazio.
KASSINAO_DEDICATED_DOCKER_HOST_ACK=

# Snapshots operacionais de deploy que falhou expiram mesmo sem outro deploy.
# O intervalo aceito pelo kit é 1..168 horas; 72 horas é o padrão publicado.
KASSINAO_ROLLBACK_RETENTION_HOURS=72

# Estes caminhos pertencem à instância e ficam fora de qualquer checkout Git.
KASSINAO_DATA_ROOT=/var/lib/kassinao
KASSINAO_RECORDINGS_DIR=/var/lib/kassinao/recordings
KASSINAO_STATE_DIR=/var/lib/kassinao/state
KASSINAO_AUTH_DIR=/var/lib/kassinao/auth
# Dedicated pode manter 1000:1000. Shared exige que o operador preencha um par
# numérico privado na faixa 61000..61183, sem criar conta/grupo Linux e ausente
# de contas, subuid/subgid, processos, arquivos e containers vizinhos. O exemplo
# público permanece vazio e nunca escolhe a identidade da sua VPS.
KASSINAO_MODEL_CACHE_DIR=/var/lib/kassinao/cache
KASSINAO_UID=
KASSINAO_GID=
# Adapter shared: identidade do file-container LUKS2 montado em DATA_ROOT.
# O backing file fica fora do mount; mapper não inclui /dev/mapper/.
KASSINAO_SHARED_LUKS_BACKING_FILE=
KASSINAO_SHARED_LUKS_MAPPER=
KASSINAO_SHARED_LUKS_UUID=
# No adapter shared, estes dois arquivos ficam dentro do mount LUKS. Segredos
# nunca são persistidos no kit/release nem no banco de metadados do Docker.
KASSINAO_SHARED_APP_ENV_FILE=/var/lib/kassinao/config/app.env
KASSINAO_SHARED_TUNNEL_TOKEN_FILE=/var/lib/kassinao/config/cloudflared-token
KASSINAO_HOST_PORT=8080
KASSINAO_PUBLIC_HOST_PORT=8081

# Topologia pública, sem credenciais Discord/provider. APP_URL e MCP_URL também
# existem no app.env porque o core precisa gerar links e validar tokens.
APP_URL=
MCP_URL=
PUBLIC_URL=
DOCS_URL=
SOURCE_URL=
REPO_PUBLIC=true
TRUST_PROXY_HOPS=1

# Produção recomendada: túnel + site/docs num processo sem segredos. O
# injector remove o profile tunnel quando nenhum token é fornecido.
COMPOSE_PROFILES=tunnel,split-public
TUNNEL_TOKEN=
