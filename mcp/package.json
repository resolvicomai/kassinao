{
  "name": "kassinao-mcp",
  "version": "1.0.3",
  "description": "MCP connector for Kassinão — ask your Discord meeting recordings (transcripts, minutes, action items) from Claude Desktop, Cursor and other MCP clients.",
  "author": "Mauro Marques (resolvicomai)",
  "homepage": "https://kassinao.resolvicomai.app/en/docs#mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/resolvicomai/kassinao.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/resolvicomai/kassinao/issues"
  },
  "type": "module",
  "bin": {
    "kassinao-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "discord",
    "kassinao",
    "meetings",
    "transcription"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "license": "AGPL-3.0-or-later"
}
