{
  "name": "kassinao",
  "version": "1.0.0",
  "description": "Self-hosted Discord voice recorder with per-speaker AI transcription and meeting minutes.",
  "license": "MIT",
  "author": "Mauro Marques (resolvicomai)",
  "homepage": "https://github.com/resolvicomai/kassinao#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/resolvicomai/kassinao.git"
  },
  "bugs": {
    "url": "https://github.com/resolvicomai/kassinao/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "voice-recording",
    "transcription",
    "meeting-notes",
    "ai",
    "whisper",
    "self-hosted",
    "craig",
    "typescript"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.6",
    "archiver": "^8.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.8.4",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^8.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
