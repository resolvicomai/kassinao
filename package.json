{
  "name": "kassinao",
  "version": "1.4.18",
  "private": true,
  "description": "Open-source, self-hosted Discord bot for recording calls with separate Discord-account audio tracks and optional transcripts, minutes, and MCP access.",
  "license": "AGPL-3.0-or-later",
  "author": "Mauro Marques",
  "homepage": "https://kassinao.cloud/en",
  "repository": {
    "type": "git",
    "url": "https://github.com/resolvicomai/kassinao.git"
  },
  "bugs": {
    "url": "https://github.com/resolvicomai/kassinao/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "voice-recording",
    "transcription",
    "meeting-notes",
    "meeting-transcription",
    "ai",
    "mcp",
    "open-source",
    "whisper",
    "self-hosted",
    "typescript"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "deploy",
    "docs",
    "scripts/*.cjs",
    "scripts/*.py",
    "scripts/*.sh",
    "scripts/*.ts",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "typecheck:preview": "tsc -p tsconfig.preview.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "assets:launch": "node scripts/render-launch-assets.cjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@snazzah/davey": "^0.1.6",
    "archiver": "^7.0.1",
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "libsodium-wrappers": "^0.7.15",
    "prism-media": "^1.3.5",
    "shell-quote": "1.10.0"
  },
  "overrides": {
    "undici": "^6.27.0",
    "tar": "^7.5.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^6.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
